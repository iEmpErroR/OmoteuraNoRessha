Shader "Custom/DownSampleShader"
{
    Properties
    {
        _DownSampleFactor("Down Sample Factor", Float) = 1 // 口头约束:下采样因子只存在 1x、2x、4x，前两者依赖GPU自动处理，4x需要手动单独处理
    }
    SubShader
    {
        Tags
        {
            "RenderPipeline"="UniversalPipeline"
        }

        Pass
        {
            Name "DownSample"

            Cull Back
            ZWrite Off
            ZTest Always
            Blend SrcAlpha OneMinusSrcAlpha

            HLSLPROGRAM

            #include "Packages/com.unity.render-pipelines.universal/ShaderLibrary/Core.hlsl"
            #pragma vertex vert
            #pragma fragment frag

            struct Attributes
            {
                uint vertexID : SV_VertexID;
            };

            struct Varyings
            {
                float4 positionCS : SV_POSITION;
                float2 uv : TEXCOORD0;
            };

            TEXTURE2D_X(_CameraColorTexture);
            SAMPLER(sampler_linear_clamp_CameraColorTexture);
            float4 _CameraColorTexture_TexelSize; // x = 1/width, y = 1/height, z = width, w = height

            CBUFFER_START(UnityPerMaterial)
                float _DownSampleFactor;  
            CBUFFER_END

            Varyings vert(Attributes input)
            {
                Varyings output;

                // 基本变换
                output.positionCS = GetFullScreenTriangleVertexPosition(input.vertexID);
                output.uv = GetFullScreenTriangleTexCoord(input.vertexID);

                return output;
            }

            half4 frag(Varyings input) : SV_Target
            {
                half4 finalColor = half4(1, 1, 1, 1);

                if (_DownSampleFactor != 4.0)
                {
                    // 1x或2x下采样，直接采样
                    finalColor = SAMPLE_TEXTURE2D_X(_CameraColorTexture, sampler_linear_clamp_CameraColorTexture, input.uv);
                }
                else
                {
                    // 4x下采样，分解成4个2x2区域，通过硬件自动线性平均处理再手动平均处理
                    float2 texelSize = float2(_CameraColorTexture_TexelSize.x, _CameraColorTexture_TexelSize.y);
                    half4 colorSum = half4(0, 0, 0, 0);
                    colorSum += SAMPLE_TEXTURE2D_X(_CameraColorTexture, sampler_linear_clamp_CameraColorTexture, input.uv + texelSize * float2(-1, -1));
                    colorSum += SAMPLE_TEXTURE2D_X(_CameraColorTexture, sampler_linear_clamp_CameraColorTexture, input.uv + texelSize * float2(1, -1));
                    colorSum += SAMPLE_TEXTURE2D_X(_CameraColorTexture, sampler_linear_clamp_CameraColorTexture, input.uv + texelSize * float2(-1, 1));
                    colorSum += SAMPLE_TEXTURE2D_X(_CameraColorTexture, sampler_linear_clamp_CameraColorTexture, input.uv + texelSize * float2(1, 1));
                    finalColor = colorSum * 0.25; // 平均值
                }

                return finalColor;
            }

            ENDHLSL

        }
    }
}
