Shader "Custom/BilateralFilterShader"
{
	Properties
	{
		_BlurRadius("Blur Radius", Range(0.1, 5.0)) = 1.0
		_AOKouka("AO Effect", Range(0.0, 1.0)) = 1.0
		_DebugSSAO("Debug SSAO", Float) = 0.0
	}
	SubShader
	{
		Tags { "RenderPipeline"="UniversalPipeline" }

		HLSLINCLUDE

		#include "Packages/com.unity.render-pipelines.universal/ShaderLibrary/Core.hlsl"

		struct Attributes
		{
			uint vertexID : SV_VertexID;
		};

		struct Varyings_Bilatera
		{
			float4 positionCS : SV_POSITION;
			float2 uv[5] : TEXCOORD0;
		};

		// 在此处定义所需的纹理和常量缓冲区
		TEXTURE2D_X(_SceneColorTexture);
		SAMPLER(sampler_linear_clamp_SceneColorTexture);
		TEXTURE2D_X(_NormalsTexture);
		SAMPLER(sampler_linear_clamp_NormalsTexture);
		TEXTURE2D_X(_BilateralFilterTexture_1);
		SAMPLER(sampler_linear_clamp_BilateralFilterTexture_1);
		float4 _BilateralFilterTexture_1_TexelSize;
		TEXTURE2D_X(_BilateralFilterTexture_2);
		SAMPLER(sampler_linear_clamp_BilateralFilterTexture_2);
		float4 _BilateralFilterTexture_2_TexelSize;

		CBUFFER_START(UnityPerMaterial)
			float _BlurRadius;
			float _AOKouka;
			uint _DebugSSAO;
		CBUFFER_END

		half3 GetNormal(float2 uv)
		{
			return UnpackNormalOctQuadEncode(SAMPLE_TEXTURE2D_X(_NormalsTexture, sampler_linear_clamp_NormalsTexture, uv).rg);
		}

		half CompareNormal(half3 n1, half3 n2)
		{
			return saturate(dot(n1, n2));
		}

		Varyings_Bilatera vert_Vertical(Attributes input)
		{
			Varyings_Bilatera output;

			output.positionCS = GetFullScreenTriangleVertexPosition(input.vertexID);
			output.uv[0] = GetFullScreenTriangleTexCoord(input.vertexID);

			float2 delta = _BilateralFilterTexture_1_TexelSize.xy * _BlurRadius;
			output.uv[1] = output.uv[0] + float2(0.0, delta.y) * 1;
			output.uv[2] = output.uv[0] + float2(0.0, delta.y) * 2;
			output.uv[3] = output.uv[0] - float2(0.0, delta.y) * 1;
			output.uv[4] = output.uv[0] - float2(0.0, delta.y) * 2;

			return output;
		}

		Varyings_Bilatera vert_Horizontal(Attributes input)
		{
			Varyings_Bilatera output;

			output.positionCS = GetFullScreenTriangleVertexPosition(input.vertexID);
			output.uv[0] = GetFullScreenTriangleTexCoord(input.vertexID);

			float2 delta = _BilateralFilterTexture_2_TexelSize.xy * _BlurRadius;
			output.uv[1] = output.uv[0] + float2(delta.x, 0.0) * 1;
			output.uv[2] = output.uv[0] + float2(delta.x, 0.0) * 2;
			output.uv[3] = output.uv[0] - float2(delta.x, 0.0) * 1;
			output.uv[4] = output.uv[0] - float2(delta.x, 0.0) * 2;

			return output;
		}

		half4 frag_Bilatera_1(Varyings_Bilatera input) : SV_Target
		{
			// 5x5高斯核权重
			const float gaussionWeights[3] = {0.4026, 0.2442, 0.0545};

			// Raw颜色
			half color0 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv[0]).r;
			half color1 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv[1]).r;
			half color2 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv[2]).r;
			half color3 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv[3]).r;
			half color4 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv[4]).r;

			// 法线
			half3 normal0 = GetNormal(input.uv[0]);
			half3 normal1 = GetNormal(input.uv[1]);
			half3 normal2 = GetNormal(input.uv[2]);
			half3 normal3 = GetNormal(input.uv[3]);
			half3 normal4 = GetNormal(input.uv[4]);

			// 权重
			float weight0 = gaussionWeights[0];
			float weight1 = gaussionWeights[1] * CompareNormal(normal0, normal1);
			float weight2 = gaussionWeights[2] * CompareNormal(normal0, normal2);
			float weight3 = gaussionWeights[1] * CompareNormal(normal0, normal3);
			float weight4 = gaussionWeights[2] * CompareNormal(normal0, normal4);

			// 最终颜色
			half finalColor = color0 * weight0;
			finalColor += color1 * weight1;
			finalColor += color2 * weight2;
			finalColor += color3 * weight3;
			finalColor += color4 * weight4;
			finalColor /= (weight0 + weight1 + weight2 + weight3 + weight4 + 1e-5);

			return half4(finalColor, finalColor, finalColor, 1.0);
		}

		half4 frag_Bilatera_2(Varyings_Bilatera input) : SV_Target
		{
			// 5x5高斯核权重
			const float gaussionWeights[3] = {0.4026, 0.2442, 0.0545};

			// Raw颜色
			half color0 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_2, sampler_linear_clamp_BilateralFilterTexture_2, input.uv[0]).r;
			half color1 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_2, sampler_linear_clamp_BilateralFilterTexture_2, input.uv[1]).r;
			half color2 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_2, sampler_linear_clamp_BilateralFilterTexture_2, input.uv[2]).r;
			half color3 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_2, sampler_linear_clamp_BilateralFilterTexture_2, input.uv[3]).r;
			half color4 = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_2, sampler_linear_clamp_BilateralFilterTexture_2, input.uv[4]).r;

			// 法线
			half3 normal0 = GetNormal(input.uv[0]);
			half3 normal1 = GetNormal(input.uv[1]);
			half3 normal2 = GetNormal(input.uv[2]);
			half3 normal3 = GetNormal(input.uv[3]);
			half3 normal4 = GetNormal(input.uv[4]);

			// 权重
			float weight0 = gaussionWeights[0];
			float weight1 = gaussionWeights[1] * CompareNormal(normal0, normal1);
			float weight2 = gaussionWeights[2] * CompareNormal(normal0, normal2);
			float weight3 = gaussionWeights[1] * CompareNormal(normal0, normal3);
			float weight4 = gaussionWeights[2] * CompareNormal(normal0, normal4);

			// 最终颜色
			half finalColor = color0 * weight0;
			finalColor += color1 * weight1;
			finalColor += color2 * weight2;
			finalColor += color3 * weight3;
			finalColor += color4 * weight4;
			finalColor /= (weight0 + weight1 + weight2 + weight3 + weight4 + 1e-5);

			return half4(finalColor, finalColor, finalColor, 1.0);
		}

		ENDHLSL

		Pass
		{
			Name "Bilateral_Vertical"
			Tags { "LightMode"="UniversalForward" }
			
			Cull Back
			ZTest Always
			ZWrite Off
			Blend SrcAlpha OneMinusSrcAlpha

			HLSLPROGRAM

			#pragma vertex vert_Vertical
			#pragma fragment frag_Bilatera_1

			ENDHLSL
		}

		Pass
		{
			Name "Bilateral_Horizontal"
			Tags { "LightMode"="UniversalForward" }

			Cull Back
			ZTest Always
			ZWrite Off
			Blend SrcAlpha OneMinusSrcAlpha

			HLSLPROGRAM

			#pragma vertex vert_Horizontal
			#pragma fragment frag_Bilatera_2

			ENDHLSL
		}

		Pass
		{
			Name "Color*AO"
			Tags { "LightMode"="UniversalForward" }

			Cull Back
			ZTest Always
			ZWrite Off
			Blend SrcAlpha OneMinusSrcAlpha

			HLSLPROGRAM

			#pragma vertex vert
			#pragma fragment frag

			#include "Packages/com.unity.render-pipelines.universal/ShaderLibrary/Core.hlsl"

			struct Varyings
			{
				float4 positionCS : SV_POSITION;
				float2 uv : TEXCOORD0;
			};

			Varyings vert(Attributes input)
			{
				Varyings output;

				output.positionCS = GetFullScreenTriangleVertexPosition(input.vertexID);
				output.uv = GetFullScreenTriangleTexCoord(input.vertexID);

				return output;
			}

			half4 frag(Varyings input) : SV_Target
			{
				half3 color0 = SAMPLE_TEXTURE2D_X(_SceneColorTexture, sampler_linear_clamp_SceneColorTexture, input.uv).rgb;
				half ao = SAMPLE_TEXTURE2D_X(_BilateralFilterTexture_1, sampler_linear_clamp_BilateralFilterTexture_1, input.uv).r;
				half3 color1 = color0 * ao;
				half3 color2 = half3(ao, ao, ao);
				half3 finalColor = lerp(color0, color1, _AOKouka);
				half3 deBugColor = lerp(finalColor, color2, _DebugSSAO);

				return half4(deBugColor, 1);
			}

			ENDHLSL
		}
	}
}
